<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item
        android:width="250dp"
        android:height="105dp"
        android:gravity="center">
        <shape android:shape="rectangle">
            <solid android:color="@color/widget_light_background" />
            <corners android:radius="8dp" />
            <stroke
                android:width="1dp"
                android:color="@color/widget_light_text_accent" />
        </shape>
    </item>
    <item
        android:width="120dp"
        android:height="8dp"
        android:gravity="top|center_horizontal"
        android:top="8dp">
        <shape android:shape="rectangle">
            <solid android:color="@color/widget_light_text_secondary" />
            <corners android:radius="2dp" />
        </shape>
    </item>
    <item
        android:width="80dp"
        android:height="24dp"
        android:gravity="center">
        <shape android:shape="rectangle">
            <solid android:color="@color/widget_light_text_primary" />
            <corners android:radius="4dp" />
        </shape>
    </item>
    <item
        android:width="220dp"
        android:height="22dp"
        android:bottom="8dp"
        android:gravity="bottom|center_horizontal">
        <shape android:shape="rectangle">
            <solid android:color="@color/widget_light_row_highlight" />
            <corners android:radius="4dp" />
        </shape>
    </item>
</layer-list>
