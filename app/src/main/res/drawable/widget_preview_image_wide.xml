<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item
        android:width="64dp"
        android:height="28dp"
        android:gravity="center">
        <shape android:shape="rectangle">
            <solid android:color="@color/widget_light_background" />
            <corners android:radius="6dp" />
            <stroke
                android:width="1dp"
                android:color="@color/widget_light_text_accent" />
        </shape>
    </item>
    <item
        android:width="48dp"
        android:height="8dp"
        android:gravity="top|center_horizontal"
        android:top="4dp">
        <shape android:shape="rectangle">
            <solid android:color="@color/widget_light_text_primary" />
            <corners android:radius="2dp" />
        </shape>
    </item>
    <item
        android:width="40dp"
        android:height="6dp"
        android:bottom="5dp"
        android:gravity="bottom|center_horizontal">
        <shape android:shape="rectangle">
            <solid android:color="@color/widget_light_text_accent" />
            <corners android:radius="2dp" />
        </shape>
    </item>
</layer-list>
