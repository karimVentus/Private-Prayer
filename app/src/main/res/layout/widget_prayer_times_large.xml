<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_background"
    android:gravity="center_horizontal"
    android:layoutDirection="locale"
    android:orientation="vertical"
    android:paddingStart="6dp"
    android:paddingTop="6dp"
    android:paddingEnd="6dp"
    android:paddingBottom="1dp">

    <TextView
        android:id="@+id/widget_city"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="5dp"
        android:ellipsize="end"
        android:maxLines="1"
        android:textAlignment="center"
        android:textColor="@color/widget_text_secondary"
        android:textSize="12sp" />

    <TextView
        android:id="@+id/widget_hijri"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="1dp"
        android:ellipsize="end"
        android:maxLines="1"
        android:textAlignment="center"
        android:textColor="@color/widget_text_secondary"
        android:textSize="10sp"
        android:visibility="gone" />

    <TextView
        android:id="@+id/widget_event"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="3dp"
        android:ellipsize="end"
        android:maxLines="1"
        android:textAlignment="center"
        android:textColor="@color/widget_text_accent"
        android:textSize="10sp"
        android:visibility="gone" />

    <TextClock
        android:id="@+id/widget_clock"
        android:layout_width="wrap_content"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:gravity="center"
        android:textColor="@color/widget_text_primary"
        android:textSize="42sp"
        android:textStyle="bold"
        android:format12Hour="h:mm a"
        android:format24Hour="HH:mm" />

    <LinearLayout
        android:id="@+id/widget_columns"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:baselineAligned="false"
        android:gravity="center"
        android:orientation="horizontal"
        android:paddingHorizontal="2dp">

        <LinearLayout
            android:id="@+id/widget_col_0"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical"
            android:paddingTop="3dp"
            android:paddingBottom="4dp"
            android:paddingStart="2dp"
            android:paddingEnd="2dp">

            <TextView
                android:id="@+id/widget_prayer_0"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:maxLines="1"
                android:textAlignment="center"
                android:textColor="@color/widget_text_secondary"
                android:textSize="10sp" />

            <TextView
                android:id="@+id/widget_time_0"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textAlignment="center"
                android:textColor="@color/widget_text_primary"
                android:textSize="12sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/widget_countdown_0"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:textAlignment="center"
                android:textColor="@color/widget_text_accent"
                android:textSize="9sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/widget_col_1"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical"
            android:paddingTop="3dp"
            android:paddingBottom="4dp"
            android:paddingStart="2dp"
            android:paddingEnd="2dp">

            <TextView
                android:id="@+id/widget_prayer_1"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:maxLines="1"
                android:textAlignment="center"
                android:textColor="@color/widget_text_secondary"
                android:textSize="10sp" />

            <TextView
                android:id="@+id/widget_time_1"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textAlignment="center"
                android:textColor="@color/widget_text_primary"
                android:textSize="12sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/widget_countdown_1"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:textAlignment="center"
                android:textColor="@color/widget_text_accent"
                android:textSize="9sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/widget_col_2"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical"
            android:paddingTop="3dp"
            android:paddingBottom="4dp"
            android:paddingStart="2dp"
            android:paddingEnd="2dp">

            <TextView
                android:id="@+id/widget_prayer_2"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:maxLines="1"
                android:textAlignment="center"
                android:textColor="@color/widget_text_secondary"
                android:textSize="10sp" />

            <TextView
                android:id="@+id/widget_time_2"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textAlignment="center"
                android:textColor="@color/widget_text_primary"
                android:textSize="12sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/widget_countdown_2"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:textAlignment="center"
                android:textColor="@color/widget_text_accent"
                android:textSize="9sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/widget_col_3"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical"
            android:paddingTop="3dp"
            android:paddingBottom="4dp"
            android:paddingStart="2dp"
            android:paddingEnd="2dp">

            <TextView
                android:id="@+id/widget_prayer_3"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:maxLines="1"
                android:textAlignment="center"
                android:textColor="@color/widget_text_secondary"
                android:textSize="10sp" />

            <TextView
                android:id="@+id/widget_time_3"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textAlignment="center"
                android:textColor="@color/widget_text_primary"
                android:textSize="12sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/widget_countdown_3"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:textAlignment="center"
                android:textColor="@color/widget_text_accent"
                android:textSize="9sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/widget_col_4"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical"
            android:paddingTop="3dp"
            android:paddingBottom="4dp"
            android:paddingStart="2dp"
            android:paddingEnd="2dp">

            <TextView
                android:id="@+id/widget_prayer_4"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:maxLines="1"
                android:textAlignment="center"
                android:textColor="@color/widget_text_secondary"
                android:textSize="10sp" />

            <TextView
                android:id="@+id/widget_time_4"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textAlignment="center"
                android:textColor="@color/widget_text_primary"
                android:textSize="12sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/widget_countdown_4"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:textAlignment="center"
                android:textColor="@color/widget_text_accent"
                android:textSize="9sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/widget_col_5"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical"
            android:paddingTop="3dp"
            android:paddingBottom="4dp"
            android:paddingStart="2dp"
            android:paddingEnd="2dp">

            <TextView
                android:id="@+id/widget_prayer_5"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:maxLines="1"
                android:textAlignment="center"
                android:textColor="@color/widget_text_secondary"
                android:textSize="10sp" />

            <TextView
                android:id="@+id/widget_time_5"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textAlignment="center"
                android:textColor="@color/widget_text_primary"
                android:textSize="12sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/widget_countdown_5"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:textAlignment="center"
                android:textColor="@color/widget_text_accent"
                android:textSize="9sp" />
        </LinearLayout>

    </LinearLayout>

    <TextView
        android:id="@+id/widget_empty"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:textColor="@color/widget_text_secondary"
        android:textSize="13sp"
        android:visibility="gone" />

</LinearLayout>
