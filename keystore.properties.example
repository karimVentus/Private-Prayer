# Copy to keystore.properties (gitignored) and fill in paths/passwords.
# Generate keystore once:
#   keytool -genkeypair -v -keystore ~/prayertime-upload.jks \
#     -alias prayertime -keyalg RSA -keysize 2048 -validity 10000
storeFile=/home/USER/prayertime-upload.jks
storePassword=CHANGE_ME
keyAlias=prayertime
keyPassword=CHANGE_ME
